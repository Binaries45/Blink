let pi = 3.141592653;
let tau = 2 * pi;

let Person = struct {
    name: []u8,
    age: u8,

    pub fn getAge(p: Person) u8 = p.age
};

fn add(a: u32, b: u32) u32 = a + b;

fn even(n: u32) bool = if (n % 2 == 0) true else false

fn loops_test(n: u32) u32 = {
    let mut res = 0;
    loop {
        res += n;
        if (res == n * 3) break;
    };

    while (res < n * 10) res += n;

    for _ in (0..n) res += n;
}

fn main() void = {}