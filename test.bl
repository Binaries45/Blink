//! test container doc

pub let pi = 3.141592653;
pub let tau = 2 * pi;

/// the status of a person
let Status = enum {
    alive,
    just_kinda_sleepy,
    dead,
};

let Person = struct {
    name: []u8,
    age: u8 = 0,
    status: Status,

    pub fn getAge(p: Person) u8 = { p.age; }
};

// explicit fn typing
fn add(a: u32, b: u32) u32 = {
    a + b;
}

// inferred fn type, with implicit bool return type
fn even (n: u32) bool = {
    if (n % 2 == 0) true else false;
}

fn loops_test(n: u32) u32 = {
    let mut res = 0;
    loop {
        res += n;
        if (res == n * 3) break;
    };

    while (res < n * 10) res += n;

    for _ in (0..n) res += n;
}

fn main() void = {
    
}

// note : for functions, the types of params can never be inferred, so they will have to be stated somewhere,
//        but return types can be omitted and inferred by the compiler
